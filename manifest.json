{
  "manifest_version": 3,
  "name": "Resume Autofill",
  "description": "Autofill job applications using resume data",
  "version": "1.0",

  "permissions": [
  "storage",
  "activeTab",
  "tabs"
],
  "action": {
    "default_popup": "popup.html"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}